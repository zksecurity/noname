fn init_arr<NN, MM>(nn: NN, mm: MM) -> [Field; NN * 2 + MM] {
    // should use propagated values for nn mm to evaluate actual size
    let arr = [0; (nn * 2) + mm];
    return arr;
}

// current algo see -> [Field; 3 * 2 + 1] as GenericArray
fn main(pub public_input: Field) -> [Field; 7] {
    let arr = init_arr(3, 1);
    return arr;
}